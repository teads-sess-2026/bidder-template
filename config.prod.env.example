# Prod mode: bidder connects to the always-on AWS backing services instead of
# local Docker containers. Fill VM_HOST/DB_PASSWORD from Terraform outputs:
#
#   cd ../infra/terraform
#   VM_HOST=$(tofu output -raw vm_public_ip)
#   DB_PASSWORD=$(tofu output -raw db_password)
#
# then substitute below. Your machine must be in the Terraform
# data_ingress_cidrs allowlist to reach these ports.
# Copy to config.prod.env (gitignored) and run: make run-prod

DB_HOST=REPLACE_VM_HOST
DB_PORT=5432
DB_USER=bidder
DB_PASSWORD=REPLACE_DB_PASSWORD
REDIS_HOST=REPLACE_VM_HOST
REDIS_PORT=6379
SPRING_KAFKA_BOOTSTRAP_SERVERS=REPLACE_VM_HOST:9092

# bidder.timeout-ms guards biddingService.bid()'s own DB+Redis round trips.
# The 100 default assumes same-host Docker (<1ms). Over the WAN to AWS, a
# single Postgres round trip alone is ~40ms and bid() makes several, so the
# default causes "BID TIMEOUT" on most requests. SSP's own BIDDER_TIMEOUT_SECONDS
# (2s, see ssp/.env.prod) bounds the outer HTTP call, so there's headroom.
BIDDER_TIMEOUT_MS=1500

# bid() is @Transactional and holds one Hikari connection for its whole
# duration (2 finds + a save, each an AWS round trip). SSP dispatches
# AUCTIONS_PER_BATCH concurrent requests every AUCTION_LOOP_DELAY_MS, so with
# the default pool of 10, in-flight WAN-latency requests queue for a
# connection and blow past bidder.timeout-ms in bursts. Give it more headroom.
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=30
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=10
